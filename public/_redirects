# Cloudflare Redirects Configuration
# https://developers.cloudflare.com/pages/configuration/redirects/

# Force trailing slash for SEO
/products /products/
/checkout /checkout/
/wishlist /wishlist/

# Redirect old paths
/shop /products 301
/store /products 301
/catalog /products 301
