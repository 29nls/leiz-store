# ─── LEIZ STORE - Environment Variables ────────────────────────
# Salin file ini ke .env.local dan isi nilai yang sesuai
# cp .env.example .env.local

# ─── Supabase (PostgreSQL) ───────────────────────────────────
# Dapatkan kredensial ini dari Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── JWT ─────────────────────────────────────────────────────
# Ubah ini dengan string random yang kuat di production!
# Generate: openssl rand -base64 32
JWT_SECRET=your-strong-jwt-secret-here

# ─── Site URL ────────────────────────────────────────────────
# URL publik aplikasi (untuk metadata, OG image, Canonical URL, dll)
# Di Vercel, variabel ini akan otomatis diisi
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Notifikasi (Opsional) ───────────────────────────────────
# Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Discord
# DISCORD_WEBHOOK_URL=your_webhook_url

# WhatsApp
# WHATSAPP_API_KEY=your_api_key
# WHATSAPP_API_URL=your_api_url

# ─── Pembayaran (Opsional) ───────────────────────────────────
# QRIS Webhook
# QRIS_WEBHOOK_SECRET=your_webhook_secret
